# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── LLM (OpenRouter or any OpenAI-compatible endpoint) ────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Override the default model if needed (default: openai/gpt-oss-120b:free)
# WARROOM_MODEL=openai/gpt-oss-120b:free

# ── Splunk MCP Server ─────────────────────────────────────────────────────────
# Enable MCP Server in Splunk: Settings → Server Settings → MCP Server
# Token: generate a session token or use a JWT from Splunk Web
SPLUNK_MCP_ENDPOINT=https://localhost:8089/services/mcp
SPLUNK_MCP_TOKEN=your_splunk_mcp_token_here

# Alternative MCP endpoint via Splunk Web (port 8000) — use if 8089 is blocked
# SPLUNK_MCP_ENDPOINT2=http://localhost:8000/en-US/splunkd/__raw/services/mcp

# ── Splunk HEC (HTTP Event Collector) — only needed for seed script ───────────
SPLUNK_HEC_URL=http://localhost:8088/services/collector/event
SPLUNK_HEC_TOKEN=your_hec_token_here

# ── Splunk credentials — only needed for seed/cleanup scripts ─────────────────
SPLUNK_USERNAME=your_splunk_username
SPLUNK_PASSWORD=your_splunk_password
